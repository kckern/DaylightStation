<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="net.kckern.pianobridge">

    <!-- FOREGROUND_SERVICE: declared for parity with audio-bridge, though the
         service runs as a REGULAR started service with NotificationManager.notify()
         (NOT startForeground) — see DESIGN.md "Service Lifecycle". -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- INTERNET: the WebSocket + HTTP control server (localhost for the kiosk,
         LAN for the external pbctl CLI — NanoHTTPD binds all interfaces). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Read SFZ/sample assets from /sdcard/piano-instruments (legacy storage, targetSdk 29). -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- Self-update (POST /update → PackageInstaller): lets the bridge install a new
         APK of itself over the LAN control plane, so future upgrades never need ADB.
         Normal-protection appop; pre-granted once over USB with
         `appops set net.kckern.pianobridge REQUEST_INSTALL_PACKAGES allow` (persists
         across updates). This device has a Google account so it can't be a device
         owner — the system therefore shows a ONE-TAP confirm per install; there is no
         silent path here. See README "Self-update (ADB-free upgrades)". -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- ADB-replacement diagnostics (the /exec, /cpu, /logcat, /dumpsys control-plane
         endpoints). All three are protectionLevel signature|privileged|DEVELOPMENT, so
         they cannot be granted at install but CAN be granted once over USB with
         `adb shell pm grant net.kckern.pianobridge <perm>` — the grant then persists
         across reboots (lost only on uninstall). This is what lets the bridge expose,
         over HTTP on the LAN, everything ADB-over-WiFi gave us that the Fully REST API
         does not: per-process/-thread CPU (DUMP → dumpsys cpuinfo), other-app logs
         (READ_LOGS → logcat), and secure-setting writes (WRITE_SECURE_SETTINGS, e.g.
         keeping location on for BLE scans). Without the grant the endpoints still exist;
         they just see only our own process/logs. -->
    <uses-permission android:name="android.permission.READ_LOGS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.DUMP"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <!-- Bluetooth LE: the bridge CONNECTS the BLE-MIDI piano itself via
         MidiManager.openBluetoothDevice() (the job the throwaway connect app did).
         On Android 10 (API 29) a BLE scan needs BLUETOOTH_ADMIN +
         ACCESS_FINE_LOCATION (granted at runtime by MainActivity). The Android-12+
         BLUETOOTH_SCAN/CONNECT split does not apply at targetSdk 29. -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- The bridge reads the BLE-MIDI piano directly via Android MidiManager. -->
    <uses-feature
        android:name="android.software.midi"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="true" />

    <!-- usesCleartextTraffic: the bridge makes plain-HTTP calls to localhost FKB
         (ScreenWaker screenOn poke, 127.0.0.1:2323) and to arbitrary LAN hosts for
         self-update (POST /update). targetSdk 29 blocks cleartext by default, which
         silently broke the wake poke ("Cleartext HTTP traffic ... not permitted");
         allowing it is consistent with this LAN-only kiosk (which already exposes an
         unauthenticated /exec shell on :8770). -->
    <application
        android:label="Piano Bridge"
        android:usesCleartextTraffic="true"
        android:allowBackup="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="Piano Bridge">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- LEANBACK so it is launchable on TV-style devices too. -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground service (mediaPlayback): the synth host + MIDI reader + WS
             control server. Foreground so it can be (re)started under the Fully
             Kiosk lockdown and isn't killed when the kiosk reclaims foreground. -->
        <service
            android:name=".PianoBridgeService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="false" />

        <!-- Synthetic-touch AccessibilityService (PianoTouchService): TouchPulser
             dispatches a tiny gesture while notes flow so the SM-T590's OS input-
             recency frame throttle stays lifted during MIDI play (BLE-MIDI is not
             "touch" to Android). Bound by the system via BIND_ACCESSIBILITY_SERVICE;
             SELF-ENABLED over the LAN via WRITE_SECURE_SETTINGS (no USB, no manual
             toggle) — see SettingsControl.enableAccessibilityService. -->
        <service
            android:name=".PianoTouchService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/piano_touch_service" />
        </service>

        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Receives PackageInstaller callbacks for self-update (see Updater/
             InstallReceiver): on Android 10 (non device-owner) the commit returns
             STATUS_PENDING_USER_ACTION with a confirm Intent this receiver launches. -->
        <receiver
            android:name=".InstallReceiver"
            android:exported="false" />

    </application>

</manifest>
