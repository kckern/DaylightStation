<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="net.kckern.pianobridge">

    <!-- FOREGROUND_SERVICE: declared for parity with audio-bridge, though the
         service runs as a REGULAR started service with NotificationManager.notify()
         (NOT startForeground) — see DESIGN.md "Service Lifecycle". -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- INTERNET: the WebSocket + HTTP control server (localhost for the kiosk,
         LAN for the external pbctl CLI — NanoHTTPD binds all interfaces). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Read SFZ/sample assets from /sdcard/piano-instruments (legacy storage, targetSdk 29). -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- Bluetooth LE: the bridge CONNECTS the BLE-MIDI piano itself via
         MidiManager.openBluetoothDevice() (the job the throwaway connect app did).
         On Android 10 (API 29) a BLE scan needs BLUETOOTH_ADMIN +
         ACCESS_FINE_LOCATION (granted at runtime by MainActivity). The Android-12+
         BLUETOOTH_SCAN/CONNECT split does not apply at targetSdk 29. -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- The bridge reads the BLE-MIDI piano directly via Android MidiManager. -->
    <uses-feature
        android:name="android.software.midi"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="true" />

    <application
        android:label="Piano Bridge"
        android:allowBackup="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="Piano Bridge">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- LEANBACK so it is launchable on TV-style devices too. -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground service (mediaPlayback): the synth host + MIDI reader + WS
             control server. Foreground so it can be (re)started under the Fully
             Kiosk lockdown and isn't killed when the kiosk reclaims foreground. -->
        <service
            android:name=".PianoBridgeService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="false" />

        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
