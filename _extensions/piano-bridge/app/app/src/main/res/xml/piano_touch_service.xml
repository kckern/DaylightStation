<?xml version="1.0" encoding="utf-8"?>
<!-- Config for PianoTouchService. canPerformGestures is the load-bearing flag —
     it grants dispatchGesture. We subscribe to no real events (the service is a
     gesture emitter, not an observer); notificationTimeout 0. -->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/piano_touch_desc"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:notificationTimeout="0"
    android:canPerformGestures="true" />
